# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# Instagram (instagrapi logs in with these; a session file is cached after first login)
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password

# TikTok uses an exported cookies file, not username/password.
# Export with a "Get cookies.txt LOCALLY" browser extension while logged into TikTok.
TIKTOK_COOKIES=tiktok_cookies.txt

# For Kick downloads, yt-dlp can pull cookies from your browser. Set which one:
#   chrome | firefox | edge | brave | (empty to disable)
BROWSER_FOR_COOKIES=chrome

# ---- Web dashboard / multi-account ----
# The dashboard stores only the NAMES of env vars + cookie paths, never secrets.
# Define one env var per account secret, e.g.:
#   IG_PW_1=password_for_account_1
#   IG_PW_2=password_for_account_2
#   FB_TOKEN_1=EAAB...page_access_token
# TikTok accounts use a cookies file each (cookies/acct1.txt) — no env var needed.
